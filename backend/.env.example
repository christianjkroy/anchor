# PostgreSQL
DATABASE_URL=postgresql://anchor:anchor@localhost:5432/anchor

# JWT
JWT_SECRET=change-me-in-production

# LLM provider: openai | ollama
LLM_PROVIDER=openai

# OpenAI (optional; enables richer logger/analyzer/critic behavior)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (optional; local OpenAI-compatible provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=all-minilm

# R Plumber API (optional; enables R-backed statistical analysis)
R_PLUMBER_URL=http://localhost:8000

# Server
PORT=3001
NODE_ENV=development
